{
  "name": "semic-version-changer",
  "displayName": "Semic Version Changer (.NET)",
  "description": "Bulk edit .NET project versions across many .csproj files from a dedicated VS Code desktop-style UI.",
  "version": "1.0.0",
  "publisher": "semic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/semic/Semic.DotnetVersionChanger.git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/Extension.js",
  "contributes": {
    "commands": [
      {
        "command": "semic-version-changer.open",
        "title": "Semic Version Changer: Open",
        "category": "Semic Version Changer"
      },
      {
        "command": "semic-version-changer.refreshProjects",
        "title": "Semic Version Changer: Refresh Projects",
        "category": "Semic Version Changer"
      },
      {
        "command": "semic-version-changer.updateSelectedProjects",
        "title": "Semic Version Changer: Update Selected Projects",
        "category": "Semic Version Changer"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "semicVersionChangerPanelContainer",
          "title": "VERSION CHANGER",
          "icon": "media/version-changer.svg"
        }
      ]
    },
    "views": {
      "semicVersionChangerPanelContainer": [
        {
          "id": "semicVersionChangerView",
          "name": "Projects",
          "type": "webview",
          "icon": "media/version-changer.svg"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "semic-version-changer.open",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:webview && tsc -p .",
    "watch": "concurrently \"tsc -w -p .\" \"vite build --watch --config vite.config.ts\"",
    "build:webview": "vite build --config vite.config.ts",
    "watch:webview": "vite build --watch --config vite.config.ts",
    "package": "npm run compile && vsce package",
    "lint": "tsc --noEmit -p . && tsc --noEmit -p webview/tsconfig.json"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "xml-formatter": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.116.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vscode/vsce": "^3.9.0",
    "concurrently": "^9.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
